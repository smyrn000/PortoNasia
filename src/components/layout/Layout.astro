---
/**
 * Base page layout: <head>, fonts, header, footer, and global scripts.
 * Every page wraps its content in <Layout> and passes SEO props through.
 */
import '@styles/global.css';
import SEO from '@components/seo/SEO.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MusicToggle from '@components/layout/MusicToggle.astro';
import Intro from '@components/layout/Intro.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
  /** Lets the hero sit under a transparent header on the home page, etc. */
  mainClass?: string;
}
const { title, description, image, type, jsonLd, noindex, mainClass } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f3efe7" />

    <!-- Swap no-js -> js as early as possible so reveal animations can arm
         without ever risking content staying hidden. Also decide, flash-free,
         whether the "Enter" intro veil should show this session. -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.remove('no-js');
        d.classList.add('js');
        try {
          var p = location.pathname;
          var isHome = p === '/' || p === '' || /index\.html?$/.test(p);
          var sameSite = !!document.referrer && document.referrer.indexOf(location.origin) === 0;
          var navEntry = (performance.getEntriesByType && performance.getEntriesByType('navigation')[0]) || null;
          var reloaded = navEntry ? navEntry.type === 'reload'
            : (performance.navigation && performance.navigation.type === 1);
          // Show the intro on a fresh visit or reload of the home page; skip it
          // for in-site navigation (so internal links don't replay it).
          if (isHome && (!sameSite || reloaded)) d.classList.add('intro-lock');
          else d.classList.add('entered');
        } catch (e) {
          d.classList.add('intro-lock');
        }
      })();
    </script>

    <!-- Fonts: preconnect + display=swap to avoid blocking render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..450&family=Inter:wght@400;500;600&display=swap"
    />

    <SEO {title} {description} {image} {type} {jsonLd} {noindex} />
  </head>

  <body>
    <Intro />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />

    <!-- Floating ambient-sound toggle (starts on first click) -->
    <MusicToggle />

    <!-- Subtle film-grain overlay for a warmer, more tactile, premium feel -->
    <div class="grain" aria-hidden="true"></div>

    <!-- Smooth scroll (Lenis) loaded as a plain classic script from a CDN, then
         initialised inline. This deliberately avoids the JS module bundle so it
         runs in every situation — including when the page is opened directly as
         a file — where bundled module scripts are blocked by the browser. -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/lenis@1.1.18/dist/lenis.min.js"
    ></script>
    <script is:inline>
      (function () {
        try {
          // Smooth scroll is forced on for all visitors (by request), regardless
          // of the prefers-reduced-motion setting.
          var L = window.Lenis;
          if (!L) return;
          var lenis = new L({ duration: 1.15, smoothWheel: true, syncTouch: false });
          function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
          requestAnimationFrame(raf);
          window.__lenis = lenis;
          document.querySelectorAll('a[href^="#"]').forEach(function (a) {
            a.addEventListener('click', function (e) {
              var id = a.getAttribute('href');
              if (!id || id === '#') return;
              var t = document.querySelector(id);
              if (!t) return;
              e.preventDefault();
              lenis.scrollTo(t, { offset: -80 });
            });
          });
        } catch (err) { console.warn('Lenis init failed', err); }
      })();
    </script>

    <!-- Other progressive enhancements (reveal animations, 3D tilt). These are
         bundled module scripts and only run when served over http(s). -->
    <script>
      const safe = (fn: () => void) => { try { fn(); } catch (e) { console.warn(e); } };
      import('@/scripts/animations/scrollReveal').then((m) => safe(m.initReveal));
      import('@/scripts/interactions/tilt3d').then((m) => safe(m.initTilt));
    </script>
  </body>
</html>
