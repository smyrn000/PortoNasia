---
/**
 * Base page layout: <head>, fonts, header, footer, and global scripts.
 * Every page wraps its content in <Layout> and passes SEO props through.
 */
import '@styles/global.css';
import SEO from '@components/seo/SEO.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
  /** Lets the hero sit under a transparent header on the home page, etc. */
  mainClass?: string;
}
const { title, description, image, type, jsonLd, noindex, mainClass } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f3efe7" />

    <!-- Swap no-js -> js as early as possible so reveal animations can arm
         without ever risking content staying hidden. -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>

    <!-- Fonts: preconnect + display=swap to avoid blocking render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..450&family=Inter:wght@400;500;600&display=swap"
    />

    <SEO {title} {description} {image} {type} {jsonLd} {noindex} />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />

    <!-- Subtle film-grain overlay for a warmer, more tactile, premium feel -->
    <div class="grain" aria-hidden="true"></div>

    <!-- Global progressive enhancement. Each init is isolated so a failure in
         one (e.g. an optional library) can never break the others. -->
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const safe = (fn: () => void) => { try { fn(); } catch (e) { console.warn(e); } };

      import('@/scripts/animations/scrollReveal').then((m) => safe(m.initReveal));
      if (!reduce) {
        import('@/scripts/smoothScroll').then((m) => safe(m.initSmoothScroll));
      }
    </script>
  </body>
</html>
