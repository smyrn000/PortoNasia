---
import ResponsiveImage from '@components/ui/ResponsiveImage.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Index used for staggered entrance + alternating layout. */
  index?: number;
  sizes?: string;
}
const { project, index = 0, sizes = '(min-width: 56rem) 50vw, 100vw' } = Astro.props;
const { data } = project;
const href = `/projects/${data.slug ?? project.id}/`;
---

<a href={href} class="card" data-reveal data-tilt data-tilt-max="9" data-tilt-lift="10" style={`--i:${index}`}>
  <div class="card__media" data-tilt-inner>
    <ResponsiveImage
      src={data.cover.src}
      alt={data.cover.alt}
      sizes={sizes}
      ratio="4 / 3"
      class="card__img"
    />
    <span class="card__cat">{data.category}</span>
  </div>
  <div class="card__body">
    <div class="card__headline">
      <span class="card__index">{String(index + 1).padStart(2, '0')}</span>
      <h3 class="card__title">{data.title}</h3>
    </div>
    <p class="card__meta">{data.location} · {data.year}</p>
    <p class="card__summary">{data.summary}</p>
    <span class="arrow-link card__more">
      View project
      <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
        <path d="M1 6h13M9 1l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .card { display: flex; flex-direction: column; gap: 1.25rem; }
  .card__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-paper-2);
    box-shadow: var(--shadow-card);
    transform-style: preserve-3d;
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
  }
  /* CSS-only 3D pop on hover — a baseline that works even without JS.
     The tilt script upgrades this to follow the cursor when it runs. */
  .card:hover .card__media {
    transform: perspective(1000px) rotateX(3deg) rotateY(-4deg) translateY(-8px) scale(1.03);
    box-shadow: 0 34px 74px -26px rgba(31, 27, 22, 0.6);
  }
  .card__img :global(img) {
    width: 100%;
    transition: transform 0.85s var(--ease-out), filter var(--dur) var(--ease-out);
  }
  .card:hover .card__img :global(img) { transform: scale(1.06); }

  .card__cat {
    position: absolute;
    top: 1rem; left: 1rem;
    background: color-mix(in srgb, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(6px);
    padding: 0.45em 0.85em;
    font-size: var(--fs-100);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-radius: 999px;
  }

  .card__headline { display: flex; align-items: baseline; gap: 0.9rem; }
  .card__index {
    font-family: var(--font-display);
    font-size: var(--fs-300);
    color: var(--color-accent);
    font-style: italic;
  }
  .card__title { font-size: var(--fs-600); transition: color var(--dur-fast) var(--ease-out); }
  .card:hover .card__title { color: var(--color-accent-deep); }
  .card__meta {
    font-size: var(--fs-100);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.35rem;
  }
  .card__summary {
    margin-top: 0.75rem;
    color: var(--color-ink-soft);
    max-width: 46ch;
  }
  .card__more { margin-top: 1rem; color: var(--color-accent-deep); }
</style>
