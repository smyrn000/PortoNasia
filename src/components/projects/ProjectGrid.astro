---
import ProjectCard from '@components/projects/ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}
const { projects } = Astro.props;
---

<div class="project-grid" data-grid>
  {projects.map((project, i) => (
    <ProjectCard project={project} index={i} />
  ))}
</div>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 1rem + 4vw, 4.5rem) clamp(1.5rem, 0.5rem + 3vw, 3.5rem);
  }
  /* Offset every second card for an editorial, staggered rhythm */
  @media (min-width: 56rem) {
    .project-grid > :nth-child(even) { margin-top: clamp(2rem, 6vw, 5rem); }
  }
  @media (max-width: 56rem) {
    .project-grid { grid-template-columns: 1fr; }
  }
</style>
