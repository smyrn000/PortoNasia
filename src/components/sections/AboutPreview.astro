---
import ResponsiveImage from '@components/ui/ResponsiveImage.astro';
import { site } from '@lib/site';
---

<section class="section about-preview">
  <div class="container container--wide about-preview__grid">
    <div class="about-preview__media" data-reveal>
      <ResponsiveImage
        src="/images/projects/living-together/gallery/red-screen-corridor.jpg"
        alt="The signature red-screen corridor, showing Nasia Kouklaki's attention to light, rhythm and detail."
        sizes="(min-width: 60rem) 45vw, 100vw"
        ratio="4 / 5"
      />
    </div>

    <div class="about-preview__body" data-reveal>
      <p class="eyebrow">About</p>
      <h2 class="display">Technical rigour, an artist’s eye.</h2>
      <p class="lead">
        {site.name} is a passionate interior architect with a strong command of
        both the technical tools of the discipline and its art. Her work pairs
        careful planning and detailing with a feel for composition, material and
        light — interiors that are precise where they need to be, and expressive
        where it counts.
      </p>
      <a href="/about/" class="arrow-link">
        More about Nasia
        <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
          <path d="M1 6h13M9 1l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about-preview__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: clamp(2rem, 1rem + 5vw, 5.5rem);
  }
  .about-preview__media :global(.rimg) { border-radius: var(--radius); overflow: hidden; }
  .about-preview__media :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .about-preview__body h2 { font-size: var(--fs-700); margin: 0.7rem 0 1.25rem; }
  .about-preview__body .arrow-link { margin-top: 1.75rem; color: var(--color-accent-deep); }

  @media (max-width: 52rem) {
    .about-preview__grid { grid-template-columns: 1fr; }
    .about-preview__media { max-width: 26rem; }
  }
</style>
