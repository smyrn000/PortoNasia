---
import { getCollection } from 'astro:content';
import ProjectGrid from '@components/projects/ProjectGrid.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="section" id="featured">
  <div class="container container--wide">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Selected work</p>
      <h2 class="section-head__title">Projects shaped around the way people actually live.</h2>
    </div>

    <ProjectGrid projects={projects} />

    <div class="featured__more" data-reveal>
      <a href="/projects/" class="arrow-link">
        All projects
        <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
          <path d="M1 6h13M9 1l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .featured__more { margin-top: clamp(2.5rem, 1rem + 4vw, 4rem); }
</style>
