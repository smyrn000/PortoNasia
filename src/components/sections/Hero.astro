---
import ResponsiveImage from '@components/ui/ResponsiveImage.astro';
import { site } from '@lib/site';
---

<section class="hero" data-hero>
  <div class="hero__media">
    <ResponsiveImage
      src="/images/general/home-hero.jpg"
      alt="The communal dining hall from the Living Together project, bathed in warm daylight."
      sizes="100vw"
      priority
      class="hero__img"
    />
    <canvas
      class="hero__canvas"
      data-hero-canvas
      data-hero-src="/images/general/home-hero.jpg"
      aria-hidden="true"
    ></canvas>
    <div class="hero__scrim"></div>
  </div>

  <div class="container container--wide hero__content">
    <p class="eyebrow hero__eyebrow" data-hero-line>{site.role} · {site.contact.location}</p>
    <h1 class="hero__title display">
      <span data-hero-line>Spaces made</span><br />
      <span data-hero-line>to be <em>lived in</em>,</span><br />
      <span data-hero-line>together.</span>
    </h1>
    <p class="hero__tagline lead" data-hero-line>{site.tagline}</p>
    <div class="hero__actions" data-hero-line>
      <a href="/projects/" class="btn btn--accent">View the work</a>
      <a href="/about/" class="btn btn--outline">About Nasia</a>
    </div>
  </div>

  <a href="#featured" class="hero__scroll" aria-label="Scroll to projects" data-hero-line>
    <span>Scroll</span>
    <svg width="14" height="34" viewBox="0 0 14 34" fill="none" aria-hidden="true">
      <path d="M7 1v28M1 23l6 6 6-6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(34rem, 92svh, 56rem);
    display: flex;
    align-items: flex-end;
    color: var(--color-paper);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-h));
    padding-top: var(--header-h);
  }
  .hero__media { position: absolute; inset: 0; z-index: -1; }
  .hero__img { position: absolute; left: 0; right: 0; top: -8%; height: 116%; }
  .hero__img :global(img) { width: 100%; height: 100%; object-fit: cover; }
  /* WebGL canvas overlays the image; fades in once ready */
  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.9s var(--ease-out);
  }
  .hero[data-hero].is-webgl .hero__canvas { opacity: 1; }
  .hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(20, 17, 13, 0.7) 0%, rgba(20, 17, 13, 0.12) 45%, rgba(20, 17, 13, 0.25) 100%);
  }

  .hero__content { padding-bottom: clamp(3rem, 1rem + 6vw, 6rem); width: 100%; }
  .hero__eyebrow { color: rgba(245, 241, 234, 0.85); margin-bottom: 1.25rem; }
  .hero__title {
    font-size: var(--fs-900);
    font-weight: 330;
    max-width: 16ch;
    text-shadow: 0 1px 30px rgba(0, 0, 0, 0.25);
  }
  .hero__title em { font-style: italic; color: var(--color-sand); }
  .hero__tagline {
    color: rgba(245, 241, 234, 0.9);
    max-width: 42ch;
    margin-top: 1.5rem;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
  .hero__actions .btn--outline { color: var(--color-paper); border-color: rgba(245,241,234,0.5); }
  .hero__actions .btn--outline:hover { background: var(--color-paper); color: var(--color-ink); }

  .hero__scroll {
    position: absolute;
    right: var(--gutter); bottom: clamp(3rem, 1rem + 6vw, 6rem);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    font-size: var(--fs-100); letter-spacing: var(--tracking-label); text-transform: uppercase;
    color: rgba(245, 241, 234, 0.85);
  }
  .hero__scroll svg { animation: hero-bob 2.4s var(--ease-inout) infinite; }
  @keyframes hero-bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }
  @media (max-width: 40rem) { .hero__scroll { display: none; } }
  @media (prefers-reduced-motion: reduce) { .hero__scroll svg { animation: none; } }
</style>
