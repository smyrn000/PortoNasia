---
import Layout from '@components/layout/Layout.astro';
import ProjectGrid from '@components/projects/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Work"
  description="Selected interior architecture and design projects by Nasia Kouklaki — communal living, residential interiors and conceptual work."
>
  <section class="section page-intro">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>Work</p>
      <h1 class="page-intro__title display" data-reveal>
        Projects, in full.
      </h1>
      <p class="lead measure" data-reveal>
        A growing body of interior architecture and conceptual work — each
        project driven by how people move through, share and inhabit a space.
      </p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container container--wide">
      <ProjectGrid projects={projects} />
    </div>
  </section>
</Layout>

<style>
  .page-intro { padding-bottom: clamp(1.5rem, 1rem + 2vw, 3rem); }
  .page-intro__title { font-size: var(--fs-800); margin: 0.6rem 0 1.5rem; }
</style>
